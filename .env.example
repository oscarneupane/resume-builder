# ApplyMate environment template — copy to `.env` and fill in.
# .env is git-ignored. Keys here that start with `your-` trigger mock mode so the
# app stays runnable until real Supabase / Stripe creds exist.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Public Stripe key only — secret/webhook keys belong in Edge Function secrets.
STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# OPTIONAL — direct OpenAI for MVP/dev only. If set, the app calls ChatGPT
# directly (no backend needed) so AI features return real output.
# ⚠️ SECURITY: this key ships inside the app build. Use a low-limit/dev key for
# testing and DO NOT ship it in a public release — production must route AI
# through the Supabase Edge Function instead (see supabase/README.md, Part G1).
# Leave as `sk-your-...` to keep mock responses.
OPENAI_API_KEY=sk-your-openai-key
