# ApplyMate environment template — copy to `.env` and fill in.
# .env is git-ignored. Keys here that start with `your-` trigger mock mode so the
# app stays runnable until real Supabase / Stripe creds exist.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Public Stripe key only — secret/webhook keys belong in Edge Function secrets.
STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# ── AI provider (direct, MVP/dev only) ───────────────────────────────────────
# Set ONE of the keys below and the app calls that provider directly (no backend
# needed) so AI features return real output. All three use the OpenAI
# chat-completions format. Priority if several are set: Gemini → OpenRouter →
# OpenAI (so a FREE key automatically takes over a quota-blocked OpenAI key).
# ⚠️ SECURITY: these ship inside the app build — use dev keys for testing only;
# production should route AI through the Supabase Edge Function (Part G1).
#
# FREE — Google Gemini (recommended; free tier, no card):
#   get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key
#
# FREE — OpenRouter (free models, no card):
#   get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key
#
# PAID — OpenAI (needs billing/credit):
OPENAI_API_KEY=sk-your-openai-key

# Google Places — address autocomplete in the resume builder. Get a key in
# Google Cloud Console (enable "Places API"). Restrict it to your Android app.
GOOGLE_PLACES_API_KEY=your-google-places-key
