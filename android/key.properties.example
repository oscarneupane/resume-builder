# Copy to android/key.properties (git-ignored) and fill in after creating the keystore:
#   keytool -genkey -v -keystore android/app/applymate-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias applymate
storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=applymate
storeFile=applymate-release.jks
